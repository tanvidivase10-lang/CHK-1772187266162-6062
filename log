<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset=":UTF-8">
        <title>Online Exam Proctoring</title>

        <style>
        
        body{
        font-family:Arial;
        background:#f2f2f2;
        text-align:center;
        }

        .container{
        margin-top:50px;
        background:white;
        padding:30px;
        width:60%;
        margin-left:auto;
        margin-right:auto;
        border-radius:10px;
        box-shadow:0 0 10px gray;
        }

        #Warning{
        color:red;
        font-weight:bold;
        }

        button{
        padding:10px 20px;
        font-size:16px;
        background:blue;
        color:white;
        border:none;
        border-radius:5px;
        cursor:pointer;
        }
        
        </style>
        </head>
<body>
    <div class="container">
        <h2>Online Exam System</h2>
        <p id="question">
        Which of the following is an exit-controlled loop?
        </p>
       <input type="text" id="answer" placeholder="Enter your answer">
        <br><br>
        <button onclick="submitExam()">Submit</button>
        <p id="warnings">Warnings: 0</p>
        <video id="video" autoplay></video>
    </div>

    <script>
        let warnings = 0;
        
        function addWarnings(msg) {
            warnings++;
            document.getElementById("warnings").innerHTML = "Warnings: " + warnings + " | " + msg;
            
            if (warnings >= 3) {
                alert("Exam terminated due to cheating");
                window.location.reload();
            }
        }

        // Tab switching detection
        document.addEventListener("visibilitychange", function(e) {
            if (document.hidden) {
                addWarnings("Tab Switched detected");
            }
        });

        // Copy prevention
        document.addEventListener("copy", function(e) {
            e.preventDefault();
            addWarnings("Copy not allowed");
});
